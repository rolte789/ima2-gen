---
import '../styles/global.css';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
}

const { lang = 'en', title, description } = Astro.props;
const finalTitle = title ?? t(lang, 'meta.title');
const finalDesc = description ?? t(lang, 'meta.desc');
const ogTitle = t(lang, 'meta.og.title');
const ogDesc = t(lang, 'meta.og.desc');

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteRoot = 'https://lidge-jun.github.io/ima2-gen/';
const canonicalUrl = lang === 'ko' ? `${siteRoot}ko/` : siteRoot;
const ogImage = `${siteRoot}og.png`;
const faviconHref = `${base}/favicon.svg`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDesc} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={siteRoot} />
    <link rel="alternate" hreflang="ko" href={`${siteRoot}ko/`} />
    <link rel="alternate" hreflang="x-default" href={siteRoot} />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={faviconHref} />

    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&display=swap" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css" />

    <script is:inline>document.documentElement.classList.add('js');</script>

    <script is:inline>
      // Language detection — runs before paint to minimize FOUC.
      // Priority: ?lang= > localStorage('ima2:lang') > navigator.language > default(en).
      (function () {
        try {
          var BASE = '/ima2-gen';
          var KO = BASE + '/ko';
          var url = new URL(window.location.href);
          var qs = url.searchParams.get('lang');
          var stored = window.localStorage.getItem('ima2:lang');
          var path = url.pathname;
          var onKo = path === KO || path === KO + '/' || path.indexOf(KO + '/') === 0;

          if (qs === 'en' || qs === 'ko') {
            window.localStorage.setItem('ima2:lang', qs);
            if (qs === 'ko' && !onKo) {
              window.location.replace(KO + '/' + url.hash);
              return;
            }
            if (qs === 'en' && onKo) {
              window.location.replace(BASE + '/' + url.hash);
              return;
            }
            return;
          }

          if (stored === 'en' || stored === 'ko') return;

          var nav = (navigator.language || '').toLowerCase();
          var isKoBrowser = nav.indexOf('ko') === 0;
          if (isKoBrowser && !onKo) {
            window.localStorage.setItem('ima2:lang', 'ko');
            window.location.replace(KO + '/' + url.hash);
          }
        } catch (e) {
          // Fail silently — fall back to default render.
        }
      })();
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        var reveals = Array.prototype.slice.call(document.querySelectorAll('.reveal'));
        var visible = function (el) {
          var rect = el.getBoundingClientRect();
          return rect.bottom >= 0 && rect.top <= window.innerHeight;
        };
        reveals.forEach(function (el) { if (visible(el)) el.classList.add('in'); });
        if (!('IntersectionObserver' in window)) {
          reveals.forEach(function (el) { el.classList.add('in'); });
          return;
        }
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        reveals.forEach(function (el) { if (!el.classList.contains('in')) observer.observe(el); });
      })();
    </script>
  </body>
</html>
