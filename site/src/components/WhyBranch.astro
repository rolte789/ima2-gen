---
import Screenshot from './Screenshot.astro';
import { t, type Lang } from '../i18n/strings';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="std branch" id="branch">
  <div class="blob-layer branch-blob parallax-down" aria-hidden="true"><img src={`${base}/fx/blob-ribbon.webp`} alt="" loading="lazy" /></div>
  <div class="frame">
    <div class="section-tag reveal" style="--i:0">{t(lang, 'branch.tag')}</div>
    <h2 class="branch-heading chrome-text reveal" style="--i:1">{t(lang, 'branch.h.before')}<span>{t(lang, 'branch.h.em')}</span></h2>
    <p class="section-lede reveal" style="--i:2">{t(lang, 'branch.lede')}</p>
    <div class="branch-grid">
      <div class="branch-shot reveal" style="--i:3"><Screenshot src="screenshots/node-mode.png" alt={t(lang, 'branch.shot.alt')} aspect="4/3" eager /></div>
      <ol class="scenarios reveal" style="--i:4" aria-label={t(lang, 'branch.scenarios.aria')}>
        <li><span class="step prism-text">01</span><div class="body"><strong>{t(lang, 'branch.s1.strong')}</strong> {t(lang, 'branch.s1.body')}</div></li>
        <li><span class="step prism-text">02</span><div class="body"><strong>{t(lang, 'branch.s2.strong')}</strong> {t(lang, 'branch.s2.body')}</div></li>
        <li><span class="step prism-text">03</span><div class="body"><strong>{t(lang, 'branch.s3.strong')}</strong> {t(lang, 'branch.s3.body')}</div></li>
      </ol>
    </div>
  </div>
</section>

<style>
  .branch { position: relative; isolation: isolate; overflow: clip; background: var(--bg); }
  .branch-blob { z-index: -1; top: 12%; right: -16%; width: min(760px,55vw); opacity: .16; }
  .branch-blob img { width: 100%; height: auto; display: block; }
  .branch-heading { max-width: 1000px; margin: 18px 0 22px; font: 600 56px/.98 var(--font-display); letter-spacing: 0; text-wrap: balance; }
  .branch-heading span { display: block; }
  .section-lede { max-width: 680px; }
  .branch-grid { display: grid; grid-template-columns: minmax(0,1.35fr) minmax(300px,.65fr); gap: 76px; align-items: end; margin-top: 84px; }
  .branch-shot { transform: rotate(-1deg); }
  .branch-shot :global(.screenshot) { box-shadow: 0 32px 90px rgba(0,0,0,.42); }
  .scenarios { list-style: none; margin: 0; padding: 0; }
  .scenarios li { display: grid; grid-template-columns: 52px 1fr; gap: 16px; padding: 24px 0; border-top: 1px solid var(--line); }
  .scenarios li:last-child { border-bottom: 1px solid var(--line); }
  .step { font: 700 19px/1 var(--font-display); }
  .body { color: var(--text-dim); font-size: 15px; line-height: 1.6; }
  .body strong { display: block; margin-bottom: 5px; color: var(--text); font: 600 18px/1.25 var(--font-display); letter-spacing: 0; }
  @media (max-width: 900px) { .branch-heading { font-size: 44px; } .branch-grid { grid-template-columns: 1fr; gap: 42px; margin-top: 56px; } .branch-blob { width: 80vw; right: -38%; } }
  @media (max-width: 480px) { .branch-heading { font-size: 32px; } .scenarios li { grid-template-columns: 42px 1fr; gap: 10px; } }
</style>
