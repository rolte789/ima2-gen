---
import CodeCopy from './CodeCopy.astro';
import Screenshot from './Screenshot.astro';
import Marquee from './Marquee.astro';
import { t, type Lang } from '../i18n/strings';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const splash = `${base}/fx/blob-splash.webp`;
const cluster = `${base}/fx/blob-cluster.webp`;
const iridescent = `url("${base}/fx/iridescent.webp")`;
const crossLangUrl = lang === 'en' ? 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.ko.md' : 'https://lidge-jun.github.io/ima2-gen/?lang=en';
const oneclickCmds = [
  { os: 'macOS', cmd: 'curl -fsSL https://lidge-jun.github.io/ima2-gen/install-mac.sh | bash' },
  { os: 'Windows', cmd: 'irm https://lidge-jun.github.io/ima2-gen/install-windows.ps1 | iex' },
  { os: 'Linux / WSL', cmd: 'curl -fsSL https://lidge-jun.github.io/ima2-gen/install-linux.sh | bash' },
];
const marqueeItems = ['100% LOCAL GALLERY', 'NO API KEY NEEDED', 'IMAGE + VIDEO', 'NODE BRANCHING', 'CANVAS MODE', 'OPEN SOURCE · MIT', 'CHATGPT OAUTH', 'GROK VIDEO'];
---

<section class="hero" id="top">
  <div class="frame hero-inner">
    <div class="hero-heading reveal">
      <div class="eyebrow">{t(lang, 'hero.eyebrow')}</div>
      <h1 class="h-display" id="hero-h1" aria-describedby="hero-sub">
        <span class="hero-line line-one">{t(lang, 'hero.h1.line1')}</span>
        {lang === 'en' ? (
          <span class="hero-line line-two">
            <span class="flip-slot" aria-hidden="true">
              <span class="flip-sizer">images</span>
              <span class="flip-sizer">videos</span>
              <span class="drum">
                <span class="drum-face">images</span>
                <span class="drum-face">videos</span>
                <span class="drum-face">images</span>
                <span class="drum-face">videos</span>
              </span>
              <span class="drum-shade"></span>
            </span>
            <span class="visually-hidden">images</span>{' you'}
          </span>
        ) : (
          <span class="hero-line line-two">{t(lang, 'hero.h1.line2')}</span>
        )}
        <span class="hero-line line-em" style={`--img:${iridescent}`}>{t(lang, 'hero.h1.em')}</span>
      </h1>
      <div class="blob-layer splash parallax-up" aria-hidden="true"><img src={splash} alt="" /></div>
    </div>

    <div class="hero-lower">
      <div class="hero-copy reveal" style="--i:1">
        <p class="sub" id="hero-sub">{t(lang, 'hero.sub')}</p>
        <CodeCopy command={t(lang, 'hero.cta.cmd')} />
        <details class="oneclick-details">
          <summary class="oneclick-summary">{lang === 'ko' ? '원클릭 설치 (npm 필요 없음)' : 'One-Click Install (no npm required)'}<span class="oneclick-chevron" aria-hidden="true"></span></summary>
          <div class="oneclick-body glass-panel">
            <p class="oneclick-desc">{lang === 'ko' ? 'Node.js가 없어도 됩니다. 환경을 감지하고, 필요하면 Node LTS를 설치한 뒤 ima2-gen을 설치합니다.' : "Don't have Node.js? The script detects your environment, installs Node LTS if needed, then installs ima2-gen."}</p>
            {oneclickCmds.map((item) => (
              <div class="oneclick-cmd" data-copy={item.cmd}><span class="oneclick-os">{item.os}</span><code>{item.cmd}</code><button class="oneclick-copy" type="button" aria-label={`Copy ${item.os} install command`}>Copy</button></div>
            ))}
          </div>
        </details>
        <a class="ko-link" href={crossLangUrl} target={lang === 'en' ? '_blank' : undefined} rel={lang === 'en' ? 'noopener' : undefined}>{t(lang, 'hero.cross.lang')}</a>
      </div>

      <div class="hero-visual reveal" style="--i:2">
        <div class="shot-frame glass-panel"><Screenshot src="screenshots/classic-generate-light.png" alt={t(lang, 'hero.shot.alt')} eager /></div>
      </div>
    </div>
  </div>
  <div class="blob-layer cluster parallax-down" aria-hidden="true"><img src={cluster} alt="" /></div>
  <Marquee items={marqueeItems} />
</section>

<style>
  .hero { position: relative; isolation: isolate; min-height: 92vh; padding: 126px 0 0; border-bottom: 1px solid var(--line); overflow: clip; background: var(--bg); }
  .hero-inner { position: relative; }
  .hero-heading { position: relative; }
  .eyebrow { position: relative; z-index: 5; }
  h1 { position: relative; margin: 0; font-size: 128px; text-transform: uppercase; }
  .hero-line { position: relative; display: block; width: max-content; max-width: 100%; white-space: nowrap; }
  .line-one { z-index: 3; }
  .line-two { z-index: 1; margin-left: 7%; }
  /* Cylinder drum word roll: sizers reserve widest-word width; 4 faces at -90deg steps,
     apothem R = 0.5 * face height (line box = .94em) = .47em, so faces meet edge-to-edge.
     Drum is pushed back by -R so the resting face sits at z=0 (no perspective scale drift). */
  .flip-slot { display: inline-grid; perspective: 800px; vertical-align: baseline; }
  .flip-sizer { grid-area: 1 / 1; visibility: hidden; }
  .drum { --drum-r: .47em; --drum-rot: 0deg; grid-area: 1 / 1; display: grid; transform-style: preserve-3d; transform: translateZ(calc(-1 * var(--drum-r))) rotateX(var(--drum-rot)); will-change: transform; }
  html.js .drum { transition: transform .65s cubic-bezier(.22, .9, .24, 1.04); }
  html.js .drum.drum-snap { transition: none; }
  .drum-face { grid-area: 1 / 1; backface-visibility: hidden; }
  .drum-face:nth-child(1) { transform: rotateX(0deg) translateZ(var(--drum-r)); }
  .drum-face:nth-child(2) { transform: rotateX(-90deg) translateZ(var(--drum-r)); }
  .drum-face:nth-child(3) { transform: rotateX(-180deg) translateZ(var(--drum-r)); }
  .drum-face:nth-child(4) { transform: rotateX(-270deg) translateZ(var(--drum-r)); }
  /* Static drum-housing scrims: entering/exiting faces pass through the darkened edge bands. */
  .drum-shade { grid-area: 1 / 1; pointer-events: none; transform: translateZ(2px); background: linear-gradient(to bottom, rgba(11, 11, 15, .55), transparent 28%, transparent 72%, rgba(11, 11, 15, .55)); }
  .line-em { z-index: 3; margin-left: auto; color: transparent; background-image: var(--img); background-size: 145% auto; background-position: 35% 42%; -webkit-background-clip: text; background-clip: text; filter: saturate(1.4) brightness(1.75) contrast(1.05); }
  html.js .line-em { animation: hero-foil 10s ease-in-out infinite alternate; }
  .splash { z-index: 2; top: -18%; left: 28%; width: min(52vw, 690px); }
  .splash img { animation-duration: 8.5s; }
  .hero-lower { position: relative; z-index: 6; display: grid; grid-template-columns: minmax(300px, .72fr) minmax(440px, 1.28fr); align-items: end; gap: 54px; margin-top: -42px; }
  .hero-copy { position: relative; z-index: 4; padding-bottom: 44px; }
  .sub { max-width: 520px; margin: 0 0 24px; color: var(--text-dim); font-size: 17px; line-height: 1.6; }
  .hero-copy :global(.codeblock) { max-width: 540px; }
  .hero-visual { position: relative; z-index: 3; }
  .shot-frame { position: relative; z-index: 2; padding: 7px; box-shadow: 0 32px 90px rgba(0,0,0,.62); transform: rotate(-4deg); transform-origin: 50% 80%; }
  .shot-frame :global(.screenshot) { border: 0; box-shadow: none; }
  .cluster { z-index: 2; width: min(38vw, 550px); right: -60px; top: 480px; opacity: .78; }
  .cluster img { animation-duration: 6.5s; }
  .oneclick-details { margin: 10px 0 8px; max-width: 540px; }
  .oneclick-summary { display: inline-flex; align-items: center; gap: 7px; padding: 5px 0; list-style: none; border-bottom: 1px solid var(--line); color: var(--text-dim); font-family: var(--font-mono); font-size: 11px; cursor: pointer; }
  .oneclick-summary::-webkit-details-marker { display: none; }
  .oneclick-summary::marker { content: ''; }
  .oneclick-chevron { width: 6px; height: 6px; border-right: 1px solid currentColor; border-bottom: 1px solid currentColor; transform: rotate(45deg); transition: transform .2s ease; }
  details[open] .oneclick-chevron { transform: rotate(225deg); }
  .oneclick-body { margin-top: 10px; padding: 13px; }
  .oneclick-desc { margin-bottom: 10px; color: var(--text-dim); font-size: 12px; line-height: 1.5; }
  .oneclick-cmd { display: grid; grid-template-columns: 72px minmax(0,1fr) auto; align-items: center; gap: 8px; margin-top: 6px; }
  .oneclick-os, .oneclick-copy { font-family: var(--font-mono); font-size: 9px; }
  .oneclick-os { color: #7ad7ff; }
  .oneclick-cmd code { overflow-x: auto; padding: 4px 7px; border: 1px solid var(--line); border-radius: 4px; color: var(--text-dim); font-family: var(--font-mono); font-size: 9px; white-space: nowrap; }
  .oneclick-copy { padding: 4px 7px; border: 1px solid var(--line); border-radius: 4px; color: var(--text-dim); }
  .oneclick-copy:hover, .oneclick-copy.copied { border-color: #7ad7ff; color: var(--text); }
  .ko-link { display: inline-block; padding-bottom: 3px; border-bottom: 1px solid var(--line); color: var(--muted); font-family: var(--font-mono); font-size: 10px; }
  .hero > :global(.marquee-slot) { position: relative; z-index: 8; margin-top: -12px; }
  @keyframes hero-foil { to { background-position: 70% 42%; } }

  @media (min-width: 1441px) { h1 { font-size: 148px; } }
  @media (min-width: 1100px) {
    .hero-copy :global(.codeblock) { width: 500px; max-width: 500px; }
    .hero-copy :global(.codeblock .cmd) { font-size: 13px; white-space: nowrap; overflow-wrap: normal; }
    .shot-frame { margin-left: 60px; }
  }
  @media (min-width: 1100px) and (max-width: 1240px) {
    .shot-frame { margin-left: 100px; }
  }
  @media (max-width: 1100px) { h1 { font-size: 104px; } .hero-lower { margin-top: -16px; grid-template-columns: .8fr 1.2fr; gap: 32px; } }
  @media (max-width: 768px) {
    .hero { min-height: 92vh; padding-top: 102px; }
    h1 { font-size: 72px; }
    .line-two { margin-left: 3%; }
    .splash { top: -32%; left: 24%; width: 30vw; opacity: .64; }
    .hero-lower { grid-template-columns: 1fr; gap: 20px; margin-top: 18px; }
    .hero-copy { padding-bottom: 0; }
    .sub { max-width: 600px; font-size: 15px; }
    .hero-visual { width: 84%; margin: 0 0 -12px auto; }
    .shot-frame { transform: rotate(-2deg); }
    .cluster { width: 58vw; right: -44px; top: 500px; }
    .hero > :global(.marquee-slot) { margin-top: 0; }
  }
  @media (max-width: 480px) {
    .hero { padding-top: 88px; }
    h1 { font-size: 44px; }
    .hero-line { white-space: normal; }
    .splash { top: 32px; left: 30%; width: 14vw; opacity: .5; }
    .hero-lower { margin-top: 24px; }
    .hero-visual { width: 92%; }
    .cluster { width: 68vw; right: -56px; top: 430px; }
    .oneclick-cmd { grid-template-columns: 1fr auto; }
    .oneclick-os { grid-column: 1 / -1; }
  }
  :global(html[lang='ko']) h1 { font-size: 88px; text-transform: none; }
  :global(html[lang='ko']) .line-two { margin-left: 4%; }
  :global(html[lang='ko']) .hero-lower { margin-top: 40px; }
  @media (min-width: 1441px) { :global(html[lang='ko']) h1 { font-size: 100px; } }
  @media (max-width: 1100px) { :global(html[lang='ko']) h1 { font-size: 72px; } :global(html[lang='ko']) .hero-lower { margin-top: 32px; } }
  @media (max-width: 768px) { :global(html[lang='ko']) h1 { font-size: 52px; } :global(html[lang='ko']) .hero-lower { margin-top: 24px; } }
  @media (max-width: 480px) { :global(html[lang='ko']) h1 { font-size: 32px; } }
  @media (prefers-reduced-motion: reduce) {
    html.js .line-em { animation: none; }
    html.js .drum { transition: none !important; --drum-rot: 0deg !important; }
  }
</style>

<script>
  // Cylinder drum word roll (en hero only; the drum does not exist on ko).
  (() => {
    if (!document.documentElement.classList.contains('js')) return;
    const drum = document.querySelector<HTMLElement>('.flip-slot .drum');
    if (!drum) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    let angle = 0;
    // After a full revolution, rewind by 360deg with the transition off: -360 === 0 visually,
    // so the accumulated angle stays bounded with no visible jump.
    drum.addEventListener('transitionend', () => {
      if (angle > -360) return;
      while (angle <= -360) angle += 360;
      drum.classList.add('drum-snap');
      drum.style.setProperty('--drum-rot', `${angle}deg`);
      void drum.offsetWidth;
      drum.classList.remove('drum-snap');
    });
    window.setInterval(() => {
      if (document.hidden || reduce.matches) return;
      angle -= 90;
      drum.style.setProperty('--drum-rot', `${angle}deg`);
    }, 2800);
  })();

  document.querySelectorAll<HTMLElement>('.oneclick-cmd').forEach((row) => {
    const cmd = row.getAttribute('data-copy') ?? '';
    const btn = row.querySelector<HTMLButtonElement>('.oneclick-copy');
    const code = row.querySelector<HTMLElement>('code');
    const doCopy = async () => {
      try {
        await navigator.clipboard.writeText(cmd);
        if (btn) {
          const original = btn.textContent;
          btn.textContent = 'Copied';
          btn.classList.add('copied');
          window.setTimeout(() => { btn.textContent = original ?? 'Copy'; btn.classList.remove('copied'); }, 1400);
        }
      } catch (err) { console.warn('Clipboard write failed', err); }
    };
    btn?.addEventListener('click', doCopy);
    code?.addEventListener('click', doCopy);
  });
</script>
