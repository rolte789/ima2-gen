---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  aspect?: string;
  eager?: boolean;
}

const { src, alt, caption, aspect, eager = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const cleanSrc = src.replace(/^\//, '');
const href = `${base}/${cleanSrc}`;
const loading = eager ? 'eager' : 'lazy';
const fetchpriority = eager ? 'high' : 'auto';
---

<figure class="screenshot" style={aspect ? `--shot-aspect: ${aspect};` : undefined}>
  <img
    src={href}
    alt={alt}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .screenshot {
    margin: 0;
    border: 1px solid var(--glass-line);
    border-radius: 8px;
    overflow: hidden;
    background: var(--panel);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.58), 0 0 0 1px rgba(255, 255, 255, 0.025);
  }
  .screenshot img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: var(--shot-aspect, auto);
    object-fit: cover;
  }
  .screenshot figcaption {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    padding: 10px 14px;
    border-top: 1px solid var(--line);
    letter-spacing: 0.04em;
  }
</style>
