---
interface Props {
  items: string[];
  angle?: number;
  duration?: number;
}

const { items, angle = -2, duration = 28 } = Astro.props;
---

<div class="marquee-slot" aria-label={items.join(', ')} style={`--angle:${angle}deg;--duration:${duration}s`}>
  <div class="marquee-band">
    <div class="marquee-track">
      {[false, true].map((hidden) => (
        <div class="marquee-group" aria-hidden={hidden ? 'true' : undefined}>
          {items.map((item) => (
            <><span class="marquee-item">{item}</span><span class="marquee-sep prism-text" aria-hidden="true">✦</span></>
          ))}
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .marquee-slot { position: relative; height: 120px; overflow-x: clip; overflow-y: visible; }
  .marquee-band { position: absolute; top: 27px; left: -2vw; width: 104vw; height: 66px; display: flex; align-items: center; overflow: hidden; transform: rotate(var(--angle)); transform-origin: center; background: #0e0e13; border-top: 1px solid var(--glass-line); border-bottom: 1px solid var(--glass-line); box-shadow: 0 12px 34px rgba(0,0,0,.4); }
  .marquee-track { display: flex; width: max-content; animation: marquee var(--duration) linear infinite; }
  .marquee-group { display: flex; align-items: center; flex: 0 0 auto; }
  .marquee-item { padding: 0 26px; font-family: var(--font-display); font-size: 15px; font-weight: 600; line-height: 1; letter-spacing: .06em; white-space: nowrap; }
  .marquee-sep { flex: 0 0 auto; font-size: 17px; line-height: 1; }
  @keyframes marquee { to { transform: translateX(-50%); } }
  @media (max-width: 768px) { .marquee-slot { height: 96px; } .marquee-band { top: 21px; height: 54px; } .marquee-item { padding: 0 18px; font-size: 13px; } }
</style>
