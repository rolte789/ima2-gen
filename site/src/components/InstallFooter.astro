---
import CodeCopy from './CodeCopy.astro';
import { t, type Lang } from '../i18n/strings';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const repoUrl = 'https://github.com/lidge-jun/ima2-gen';
const npmUrl = 'https://www.npmjs.com/package/ima2-gen';
const koReadme = 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.ko.md';
const jaReadme = 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.ja.md';
const zhReadme = 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.zh-CN.md';
---

<section class="std install-section" id="install">
  <div class="frame">
    <div class="section-tag reveal" style="--i:0">{t(lang, 'install.tag')}</div>
    <h2 class="install-heading chrome-text reveal" style="--i:1">{t(lang, 'install.h.before')}<span>{t(lang, 'install.h.em')}</span></h2>
    <p class="section-lede reveal" style="--i:2">{t(lang, 'install.lede')}</p>
    <div class="install-flow">
      <div class="install-codes reveal" style="--i:3"><CodeCopy command="npm install -g ima2-gen" /><CodeCopy command="ima2 setup" /><CodeCopy command="ima2 serve" /></div>
      <div class="install-meta reveal" style="--i:4">
        <div class="oneclick">
          <p class="oneclick-title">{lang === 'ko' ? '원클릭 설치 (npm 필요 없음)' : 'One-Click Install (no npm required)'}</p>
          <div class="oneclick-cmds">
            <div class="oneclick-row"><span class="oneclick-os">macOS</span><code>curl -fsSL https://lidge-jun.github.io/ima2-gen/install-mac.sh | bash</code></div>
            <div class="oneclick-row"><span class="oneclick-os">Windows</span><code>irm https://lidge-jun.github.io/ima2-gen/install-windows.ps1 | iex</code></div>
            <div class="oneclick-row"><span class="oneclick-os">Linux / WSL</span><code>curl -fsSL https://lidge-jun.github.io/ima2-gen/install-linux.sh | bash</code></div>
          </div>
        </div>
        <div class="badges"><span class="badge prism-text">{t(lang, 'install.badge.npm')}</span><span class="badge">{t(lang, 'install.badge.node')}</span><span class="badge">{t(lang, 'install.badge.mit')}</span></div>
        <ul class="links" aria-label={t(lang, 'install.links.aria')}>
          <li><a href={repoUrl} target="_blank" rel="noopener"><span>{t(lang, 'install.link.repo')}</span><span aria-hidden="true">↗</span></a></li>
          <li><a href={npmUrl} target="_blank" rel="noopener"><span>{t(lang, 'install.link.npm')}</span><span aria-hidden="true">↗</span></a></li>
          <li><a href={koReadme} target="_blank" rel="noopener"><span>{t(lang, 'install.link.ko')}</span><span aria-hidden="true">↗</span></a></li>
          <li><a href={jaReadme} target="_blank" rel="noopener"><span>{t(lang, 'install.link.ja')}</span><span aria-hidden="true">↗</span></a></li>
          <li><a href={zhReadme} target="_blank" rel="noopener"><span>{t(lang, 'install.link.zh')}</span><span aria-hidden="true">↗</span></a></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .install-section { overflow: clip; }
  .install-heading { max-width: 1100px; margin: 18px 0 22px; font: 600 64px/.96 var(--font-display); letter-spacing: 0; text-wrap: balance; }
  .install-heading span { display: block; }
  .install-flow { display: flex; flex-direction: column; gap: 48px; max-width: 860px; margin-top: 68px; }
  .install-codes { display: flex; flex-direction: column; gap: 12px; }
  .install-codes :global(.codeblock) { min-height: 72px; padding: 18px 20px; font-size: 15px; }
  .install-meta { display: flex; flex-direction: column; gap: 22px; }
  .oneclick-title { margin: 0 0 14px; font: 600 16px/1.3 var(--font-display); letter-spacing: 0; }
  .oneclick-cmds { display: flex; flex-direction: column; }
  .oneclick-row { display: grid; grid-template-columns: 82px minmax(0,1fr); gap: 12px; padding: 12px 0; border-top: 1px solid var(--line); }
  .oneclick-row:last-child { border-bottom: 1px solid var(--line); }
  .oneclick-os { color: var(--text); font: 600 10px/1.6 var(--font-mono); letter-spacing: .06em; text-transform: uppercase; }
  .oneclick-row code { min-width: 0; color: var(--text-dim); font: 400 11px/1.7 var(--font-mono); white-space: normal; overflow-wrap: anywhere; word-break: break-all; }
  .badges { display: flex; flex-wrap: wrap; gap: 8px; }
  .badge { padding: 6px 10px; border: 1px solid var(--glass-line); border-radius: 3px; color: var(--text-dim); font: 500 10px/1 var(--font-mono); letter-spacing: .04em; }
  .links { list-style: none; margin: 0; padding: 0; }
  .links a { display: flex; justify-content: space-between; gap: 16px; padding: 12px 0; border-top: 1px solid var(--line); color: var(--text-dim); font: 500 14px/1.3 var(--font-display); transition: opacity 180ms ease; }
  .links li:last-child a { border-bottom: 1px solid var(--line); }
  .links a:hover { opacity: .68; }
  @media (max-width: 900px) { .install-heading { font-size: 48px; } .install-flow { gap: 40px; margin-top: 52px; } }
  @media (max-width: 480px) { .install-heading { font-size: 36px; } .install-codes :global(.codeblock) { min-height: 62px; padding: 14px; font-size: 12px; } .oneclick-row { grid-template-columns: 1fr; gap: 4px; } }
</style>
