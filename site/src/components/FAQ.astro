---
import { t, type Lang } from '../i18n/strings';
import InlineCode from './InlineCode.astro';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const moreHref = lang === 'ko' ? `${base}/ko/faq` : `${base}/faq`;
const items = [{ q:'faq.q1', a:'faq.a1', open:true }, { q:'faq.q2', a:'faq.a2', open:false }, { q:'faq.q3', a:'faq.a3', open:false }];
---

<section class="faq" id="faq">
  <div class="frame">
    <div class="section-tag reveal" style="--i:0">{t(lang, 'faq.tag')}</div>
    <div class="faq-list">
      {items.map((item, i) => <details class="reveal" style={`--i:${i + 1}`} open={item.open}><summary><span>{t(lang, item.q)}</span><i class="marker prism-text" aria-hidden="true">+</i></summary><p><InlineCode text={t(lang, item.a)} /></p></details>)}
    </div>
    <a class="more reveal" style="--i:4" href={moreHref}>{t(lang, 'faq.more')}</a>
  </div>
</section>

<style>
  .faq { padding: 112px 0; border-bottom: 1px solid var(--line); }
  .faq-list { margin-top: 38px; }
  details { border-top: 1px solid var(--line); }
  details:last-child { border-bottom: 1px solid var(--line); }
  summary { display: grid; grid-template-columns: minmax(0,1fr) 32px; gap: 24px; align-items: center; padding: 28px 0; cursor: pointer; list-style: none; font: 600 24px/1.2 var(--font-display); letter-spacing: 0; text-wrap: balance; }
  summary::-webkit-details-marker { display: none; }
  .marker { display: block; justify-self: end; font: 500 30px/1 var(--font-display); font-style: normal; transform: rotate(0deg); transition: transform 260ms cubic-bezier(.16,1,.3,1); }
  details[open] .marker { transform: rotate(45deg); }
  details p { max-width: 780px; margin: -8px 0 28px; color: var(--text-dim); font-size: 15px; line-height: 1.7; text-wrap: pretty; }
  .more { display: inline-block; margin-top: 32px; padding-bottom: 4px; border-bottom: 1px solid var(--text-dim); color: var(--text-dim); font: 500 12px/1.3 var(--font-mono); letter-spacing: .04em; transition: opacity 180ms ease; }
  .more:hover { opacity: .68; }
  @media (max-width: 680px) { .faq { padding: 84px 0; } summary { padding: 22px 0; font-size: 19px; } }
</style>
